{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node", "react", "react-dom"]
  },
  "include": [
    "app/**/*.js",
    "cloudflare/**/*.js",
    "collector/**/*.js",
    "components/**/*.js",
    "legacy-api/**/*.js",
    "lib/**/*.js",
    "render-api/**/*.js",
    "test/**/*.js"
  ],
  "exclude": ["node_modules", ".next", "collector/out"]
}
